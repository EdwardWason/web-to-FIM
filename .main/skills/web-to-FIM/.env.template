# Web-to-Feishu Skills - Environment Variables Template
# Copy this file to .env in the same directory and fill in your credentials
# NEVER commit .env to version control!

# ===========================================
# 飞书云文档 (Feishu Cloud Document)
# ===========================================
# 获取方式: https://open.feishu.cn/ -> 应用开发 -> 创建应用
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here

# ===========================================
# 腾讯 ima 笔记 (Tencent IMA Notes)
# ===========================================
# 获取方式: https://ima.qq.com/agent-interface
IMA_CLIENT_ID=your_ima_client_id_here
IMA_API_KEY=your_ima_api_key_here

# ===========================================
# 可选: markitdown-plus 路径
# ===========================================
# 如果 markitdown-plus 未安装到默认位置，指定路径
MARKITDOWN_PATH=
